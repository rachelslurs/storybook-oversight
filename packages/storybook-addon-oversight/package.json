{
  "name": "storybook-addon-oversight",
  "version": "0.1.3",
  "description": "See what your agent can and can't see. Diagnoses silent failures in your Storybook MCP manifest.",
  "keywords": [
    "storybook-addon",
    "storybook-addons",
    "docs",
    "test",
    "mcp",
    "ai",
    "agents",
    "docgen",
    "manifest"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rachelslurs/storybook-addon-oversight.git",
    "directory": "packages/storybook-addon-oversight"
  },
  "homepage": "https://github.com/rachelslurs/storybook-addon-oversight#readme",
  "bugs": {
    "url": "https://github.com/rachelslurs/storybook-addon-oversight/issues"
  },
  "license": "MIT",
  "author": "Rachel Cantor <rachelslurs@users.noreply.github.com> (https://github.com/rachelslurs)",
  "type": "module",
  "exports": {
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "default": "./dist/blocks.js"
    },
    "./manager": "./dist/manager.js",
    "./preset": "./dist/preset.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('./dist', { recursive: true, force: true })\"",
    "build": "tsc && tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --cache ."
  },
  "devDependencies": {
    "oversight-core": "workspace:*"
  },
  "peerDependencies": {
    "@storybook/addon-docs": "^10.3.0",
    "storybook": "^10.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "storybook": {
    "displayName": "Oversight",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://raw.githubusercontent.com/rachelslurs/storybook-addon-oversight/main/assets/oversight-icon-512.png"
  }
}
