{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    // tsup's dts pass injects a default `baseUrl`, which TS 6 flags as
    // deprecated; silence it (the main `tsc` typecheck is unaffected).
    "ignoreDeprecations": "6.0"
  },
  // Only the addon's own source. The demo's `stories` (needed by the manifest's
  // react-docgen-typescript pass) live at the repo root and are covered by the
  // root tsconfig, not this one.
  "include": ["src", "tsup.config.ts", "vitest.config.ts", "vite.config.ts"]
}
