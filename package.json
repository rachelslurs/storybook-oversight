{
  "name": "storybook-addon-oversight",
  "version": "0.0.0",
  "description": "See what your agent can and can't see. Diagnoses silent failures in your Storybook MCP manifest.",
  "keywords": [
    "storybook-addon",
    "storybook-addons",
    "docs",
    "test",
    "mcp",
    "ai",
    "agents",
    "docgen",
    "manifest"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rachelslurs/storybook-addon-oversight.git"
  },
  "homepage": "https://github.com/rachelslurs/storybook-addon-oversight#readme",
  "bugs": {
    "url": "https://github.com/rachelslurs/storybook-addon-oversight/issues"
  },
  "license": "MIT",
  "author": "Rachel Cantor (https://github.com/rachelslurs)",
  "type": "module",
  "exports": {
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "default": "./dist/blocks.js"
    },
    "./manager": "./dist/manager.js",
    "./preset": "./dist/preset.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('./dist', { recursive: true, force: true })\"",
    "build": "tsc && tsup",
    "build:watch": "tsup --watch",
    "build-storybook": "storybook build",
    "storybook": "storybook dev -p 6006",
    "start": "run-p build:watch \"storybook --quiet\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "prerelease": "zx scripts/prepublish-checks.js",
    "release": "pnpm build && auto shipit"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@types/node": "^20",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.7.0",
    "auto": "^11.3.0",
    "boxen": "^8.0.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.5.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.5.0",
    "ts-dedent": "^2.2.0",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "zx": "^8.7.1"
  },
  "peerDependencies": {
    "@storybook/addon-docs": "^10.3.0",
    "storybook": "^10.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "storybook": {
    "displayName": "Oversight",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
