{
  "name": "oversight-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Oversight: the Storybook addon and the oversight-lint CI linter, over a shared diagnostic core. Also hosts the demo Storybook.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:addon": "pnpm --filter storybook-addon-oversight run build",
    "test": "pnpm -r test",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache . --fix",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm run build:addon && storybook build",
    "start": "run-p \"build:addon --watch\" \"storybook --quiet\""
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.7.0",
    "auto": "^11.3.0",
    "boxen": "^8.0.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.5.0",
    "happy-dom": "^20.10.6",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.5.0",
    "storybook-addon-oversight": "workspace:*",
    "tailwindcss": "^4.3.2",
    "ts-dedent": "^2.2.0",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "zx": "^8.7.1"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
