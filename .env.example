# Local release credentials for `npm run release` (Auto loads these via dotenv).
# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# never commit real tokens.
#
# For CI releases (.github/workflows/release.yml) you do NOT need this file:
# add NPM_TOKEN as a GitHub Actions repo secret, and GitHub provides
# GITHUB_TOKEN to the workflow automatically.

# GitHub personal access token with `repo` + `workflow` scopes.
GH_TOKEN=

# npm access token with read + publish permission (Automation or Granular).
NPM_TOKEN=
